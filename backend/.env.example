# === Database ===
# SQLite (default, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./data/mina_agent.db
# PostgreSQL (optional, for production scale)
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# === Redis (optional, for caching) ===
REDIS_URL=

# === Reddit API ===
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=verse8_mina
REDDIT_PASSWORD=your_password
REDDIT_USER_AGENT=mina-agent:v1.0 (by /u/verse8_official)

# === Claude Code CLI ===
# Option 1: Mount ~/.claude into container (Team Premium, $0 cost)
# Option 2: Set API key for direct API access
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# === Discord Webhook (Escalation alerts) ===
DISCORD_WEBHOOK_URL=

# === API Auth ===
API_SECRET_KEY=change-me-to-a-random-string

# === Devvit Bridge ===
# DEVVIT_API_KEY=your-devvit-api-key
